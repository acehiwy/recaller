{
	"name": "${localWorkspaceFolderBasename}",
	"dockerComposeFile": [
		"../compose.yaml",
		"docker-compose.yml"
	],
	"service": "app",
	"workspaceFolder": "/home/node/app",
	"postAttachCommand": "yarn install --immutable && yarn start",
	"customizations": {
		"vscode": {
			"extensions": [
				"unifiedjs.vscode-mdx",
				"yzhang.markdown-all-in-one",
				"esbenp.prettier-vscode"
			],
			"mcp": {
				"servers": {
					"chrome-devtools": {
						"command": "npx",
						"args": [
							"chrome-devtools-mcp@latest",
							"--browser-url=http://127.0.0.1:28000"
						]
					}
				}
			}
		}
	}
}