#!/usr/bin/env bash
# =============================================================================
# teardown-worktree
#
# Safely removes one or more git worktrees and, by default, deletes their local
# branches. Refuses teardown when a worktree has unsaved changes or when its
# HEAD is neither merged into a target branch nor preserved on the remote.
#
# Usage:
#   ./teardown-worktree [OPTIONS] WORKTREE_NAME [WORKTREE_NAME ...]
# =============================================================================

set -euo pipefail

# =============================================================================
# CONFIGURATION & DEFAULTS
# =============================================================================

SCRIPT_NAME="$(basename "$0")"
REMOTE="upstream"
MERGE_TARGET="main"
DEFAULT_WORKTREES_BASE="$HOME/worktrees"
WORKTREES_BASE_INPUT="$DEFAULT_WORKTREES_BASE"
DELETE_BRANCH=true
DRY_RUN=false

# Granular force flags (replaces single --force)
FORCE_DIRTY=false
FORCE_LOCKED=false
FORCE_UNMERGED=false

declare -a TARGET_NAMES=()

# Queue: aligned by index
declare -a QUEUED_PATHS=()
declare -a QUEUED_BRANCHES=()
declare -a QUEUED_PRESERVATION_MSGS=()

CURRENT_WORKTREE_ROOT=""
WORKTREES_BASE=""
SAFE_GIT_CONTEXT=""

# Worktree registry: one entry per worktree, pipe-delimited
# Format: PATH|HEAD|BRANCH|LOCKED|PRUNABLE
declare -a WORKTREE_REGISTRY=()

# Per-iteration state (populated by resolve_target_worktree)
TARGET_WORKTREE_PATH=""
TARGET_BRANCH=""
TARGET_HEAD=""
TARGET_LOCKED=false
TARGET_PRUNABLE=false


# =============================================================================
# LOGGING & HELPERS
# =============================================================================

err()    { printf 'Error: %s\n' "$*" >&2; }
warn()   { printf 'Warning: %s\n' "$*" >&2; }
info()   { printf '%s\n' "$*"; }

# detail: supports multi-line via printf %b so \n in messages expands correctly
detail() {
    printf '    %b\n' "$*" >&2
}

run_step() {
    if [[ "$DRY_RUN" == true ]]; then
        local formatted=""
        for arg in "$@"; do
            printf -v formatted '%s%q ' "$formatted" "$arg"
        done
        info "  [dry-run] ${formatted% }"
        return 0
    fi
    "$@"
}

usage() {
    cat << EOF
Usage: $SCRIPT_NAME [OPTIONS] WORKTREE_NAME [WORKTREE_NAME ...]
       $SCRIPT_NAME -h | --help

Safely tears down git worktrees managed under the worktree base directory.

OPTIONS:
  -d, --base-dir DIR          Base directory containing managed worktrees.
                              Default: ~/worktrees
  -r, --remote NAME           Remote used to detect preserved work.
                              Default: $REMOTE
  -m, --merge-target REF      Branch or ref that counts as merged.
                              Default: $MERGE_TARGET
  -k, --keep-branch           Remove only the worktree; keep the local branch.
  -p, --dry-run               Print what would happen without changing git state.

  Force flags (use only the minimum needed):
  --force-dirty               Skip uncommitted-changes check.
  --force-locked              Skip worktree-lock check.
  --force-unmerged            Skip preservation/merge check.
  -f, --force                 Shorthand for all three force flags above.

  -h, --help                  Show this help message and exit.

EXAMPLES:
  $SCRIPT_NAME feat-ui-logic fix-auth-bug
  $SCRIPT_NAME --keep-branch feat-ui-logic
  $SCRIPT_NAME --remote origin --merge-target develop feat-ui-logic
  $SCRIPT_NAME --force-dirty feat-ui-logic    # override only dirty check
EOF
}

# =============================================================================
# REGISTRY: PARSING & LOOKUP
# =============================================================================

# Each worktree is stored as a single pipe-delimited record:
#   PATH|HEAD|BRANCH|LOCKED|PRUNABLE
# Using one record per entry avoids parallel-array index drift.

_registry_field() {
    # _registry_field RECORD FIELD_NUMBER (1-based)
    local record="$1" field="$2"
    echo "$record" | cut -d'|' -f"$field"
}

load_worktree_registry() {
    WORKTREE_REGISTRY=()

    local line="" path="" head="" branch="" locked=false prunable=false

    while IFS= read -r line; do
        if [[ -z "$line" ]]; then
            if [[ -n "$path" ]]; then
                WORKTREE_REGISTRY+=("${path}|${head}|${branch}|${locked}|${prunable}")
            fi
            path=""; head=""; branch=""; locked=false; prunable=false
            continue
        fi

        case "$line" in
            worktree\ *)              path="${line#worktree }" ;;
            HEAD\ *)                  head="${line#HEAD }" ;;
            branch\ refs/heads/*)     branch="${line#branch refs/heads/}" ;;
            detached)                 branch="(detached)" ;;
            # Explicit guard before the wildcard: skip any other "branch *" value
            # that doesn't look like a simple ref (e.g. future git edge cases)
            branch\ *)
                local raw_branch="${line#branch }"
                if [[ "$raw_branch" =~ ^[a-zA-Z0-9_./-]+$ ]]; then
                    branch="$raw_branch"
                else
                    warn "Unexpected branch format, skipping: $line"
                fi
                ;;
            locked*)                  locked=true ;;
            prunable*)                prunable=true ;;
        esac
    done < <(git -C "$CURRENT_WORKTREE_ROOT" worktree list --porcelain && printf '\n')
}

# Populate TARGET_* variables from a registry record
_populate_target_from_record() {
    local record="$1"
    TARGET_WORKTREE_PATH="$(_registry_field "$record" 1)"
    TARGET_HEAD="$(_registry_field          "$record" 2)"
    TARGET_BRANCH="$(_registry_field        "$record" 3)"
    TARGET_LOCKED="$(_registry_field        "$record" 4)"
    TARGET_PRUNABLE="$(_registry_field      "$record" 5)"
}

resolve_directory_path() {
    local path="$1"

    if [[ -z "$path" ]]; then
        err "The worktree base directory must not be empty."; return 1
    fi

    path="${path/#\~/$HOME}"

    if [[ "$path" != /* ]]; then
        path="$CURRENT_WORKTREE_ROOT/$path"
    fi

    if [[ ! -d "$path" ]]; then
        err "Worktree base directory does not exist or is not a directory: $path"
        return 1
    fi

    (cd "$path" && pwd -P)
}

# =============================================================================
# PHASE 1: VALIDATION
# =============================================================================

validate_worktree_name() {
    local name="$1"
    if [[ "$name" == *..* ]] || [[ "$name" == -* ]] || [[ ! "$name" =~ ^[a-zA-Z0-9._/-]+$ ]]; then
        err "Invalid WORKTREE_NAME: '$name'. Contains unsupported characters, '..', or starts with a hyphen."
        return 1
    fi
}

resolve_target_worktree() {
    local name="$1"
    local expected_path="$WORKTREES_BASE/$name"

    local path_match_record=""
    local branch_match_record=""
    local branch_match_count=0

    for record in "${WORKTREE_REGISTRY[@]}"; do
        local rec_path
        rec_path="$(_registry_field "$record" 1)"

        # Only consider worktrees under our managed base
        [[ "$rec_path" != "$WORKTREES_BASE"* ]] && continue

        # Path match takes priority — find it and stop scanning
        if [[ "$rec_path" == "$expected_path" ]]; then
            path_match_record="$record"
            break
        fi

        local rec_branch
        rec_branch="$(_registry_field "$record" 3)"
        if [[ -n "$rec_branch" && "$rec_branch" != "(detached)" && "$rec_branch" == "$name" ]]; then
            branch_match_record="$record"
            (( branch_match_count += 1 ))
        fi
    done

    if [[ -n "$path_match_record" ]]; then
        _populate_target_from_record "$path_match_record"; return 0
    elif (( branch_match_count == 1 )); then
        _populate_target_from_record "$branch_match_record"; return 0
    elif (( branch_match_count > 1 )); then
        err "Branch '$name' is attached to multiple managed worktrees."; return 1
    fi

    err "No managed worktree found for '$name' under: $WORKTREES_BASE"
    return 1
}

check_safety() {
    local name="$1"
    local status merged_ref remote_ref

    # --- Guard: refuse to tear down the main worktree ---
    if [[ "$(cd "$TARGET_WORKTREE_PATH" 2>/dev/null && git rev-parse --show-toplevel 2>/dev/null)" == "$TARGET_WORKTREE_PATH" ]] \
        && [[ "$(git -C "$TARGET_WORKTREE_PATH" rev-parse --git-dir 2>/dev/null)" == ".git" ]]; then
        err "'$name' appears to be the main repository worktree. Teardown refused."
        return 1
    fi

    # --- 1. Directory Existence ---
    if [[ ! -d "$TARGET_WORKTREE_PATH" ]]; then
        err "Worktree directory missing: $TARGET_WORKTREE_PATH"
        [[ "$TARGET_PRUNABLE" == true ]] && detail "Git marked this as prunable. Run 'git worktree prune'."
        return 1
    fi

    # --- 2. Dirty Check ---
    status="$(git -C "$TARGET_WORKTREE_PATH" status --short --untracked-files=normal)"
    if [[ -n "$status" && "$FORCE_DIRTY" != true ]]; then
        err "'$name' has uncommitted changes. Stash or commit them, or use --force-dirty."
        detail "Uncommitted changes:\n$status"
        return 1
    fi
    [[ -n "$status" ]] && warn "Skipping dirty check for '$name' (--force-dirty)."

    # --- 3. Lock Check ---
    if [[ "$TARGET_LOCKED" == true && "$FORCE_LOCKED" != true ]]; then
        err "'$name' is locked. Unlock it or rerun with --force-locked."
        return 1
    fi
    [[ "$TARGET_LOCKED" == true ]] && warn "Skipping lock check for '$name' (--force-locked)."

    # --- 4. Preservation Check ---
    local is_preserved=false
    local pres_msg=""

    if merged_ref="$(git -C "$CURRENT_WORKTREE_ROOT" rev-parse --verify "$MERGE_TARGET^{commit}" 2>/dev/null)"; then
        if git -C "$CURRENT_WORKTREE_ROOT" merge-base --is-ancestor "$TARGET_HEAD" "$merged_ref" 2>/dev/null; then
            is_preserved=true
            pres_msg="Preservation check passed via merge target: $MERGE_TARGET"
        fi
    fi

    if [[ "$is_preserved" == false ]] \
        && git -C "$CURRENT_WORKTREE_ROOT" config --get "remote.$REMOTE.url" >/dev/null 2>&1; then
        remote_ref="$(git -C "$CURRENT_WORKTREE_ROOT" \
            for-each-ref --format='%(refname:short)' \
            --contains "$TARGET_HEAD" \
            "refs/remotes/$REMOTE" \
            | grep -v "$REMOTE/HEAD" \
            | head -n 1)"
        if [[ -n "$remote_ref" ]]; then
            is_preserved=true
            pres_msg="Preservation check passed via remote ref: $remote_ref"
        fi
    fi

    if [[ "$is_preserved" == false && "$FORCE_UNMERGED" != true ]]; then
        err "Work in '$name' is not preserved. Push to '$REMOTE' or merge into '$MERGE_TARGET', or use --force-unmerged."
        return 1
    fi

    if [[ "$is_preserved" == false ]]; then
        warn "Skipping preservation check for '$name' (--force-unmerged)."
        pres_msg="Preservation checks bypassed by --force-unmerged."
    fi

    # Preservation message is returned via a global to avoid adding a separate
    # queue array that could drift out of sync. It is appended to
    # QUEUED_PRESERVATION_MSGS immediately after this function returns,
    # in the same code block that appends QUEUED_PATHS and QUEUED_BRANCHES.
    _LAST_PRES_MSG="$pres_msg"

    # --- 5. Branch Checkout Usage Check ---
    if [[ "$DELETE_BRANCH" == true && -n "$TARGET_BRANCH" && "$TARGET_BRANCH" != "(detached)" ]]; then
        for record in "${WORKTREE_REGISTRY[@]}"; do
            local rec_path rec_branch
            rec_path="$(_registry_field   "$record" 1)"
            rec_branch="$(_registry_field "$record" 3)"

            # Skip self
            [[ "$rec_path" == "$TARGET_WORKTREE_PATH" ]] && continue

            # Skip paths already queued for deletion
            local skip=false
            for qp in "${QUEUED_PATHS[@]+"${QUEUED_PATHS[@]}"}"; do
                [[ "$rec_path" == "$qp" ]] && { skip=true; break; }
            done
            [[ "$skip" == true ]] && continue

            if [[ "$rec_branch" == "$TARGET_BRANCH" ]]; then
                err "Branch '$TARGET_BRANCH' is checked out in surviving worktree: $rec_path"
                return 1
            fi
        done
    fi

    return 0
}

# =============================================================================
# PHASE 2: TEARDOWN
# =============================================================================

find_safe_context() {
    for record in "${WORKTREE_REGISTRY[@]}"; do
        local candidate
        candidate="$(_registry_field "$record" 1)"

        local slated=false
        for qp in "${QUEUED_PATHS[@]+"${QUEUED_PATHS[@]}"}"; do
            [[ "$candidate" == "$qp" ]] && { slated=true; break; }
        done

        if [[ "$slated" == false && -d "$candidate" ]]; then
            SAFE_GIT_CONTEXT="$candidate"
            return 0
        fi
    done

    err "Cannot find a safe git context to run teardown commands."
    return 1
}

perform_teardown() {
    local path="$1"
    local branch="$2"
    local pres_msg="$3"

    # Re-verify safe context is still available before each teardown
    if [[ ! -d "$SAFE_GIT_CONTEXT" ]]; then
        err "Safe git context has become unavailable: $SAFE_GIT_CONTEXT"
        return 1
    fi

    info "  Removing worktree: $path"
    [[ -n "$pres_msg" ]] && detail "$pres_msg"

    local rm_cmd=(git -C "$SAFE_GIT_CONTEXT" worktree remove)
    [[ "$FORCE_DIRTY" == true || "$FORCE_LOCKED" == true ]] && rm_cmd+=(--force)
    rm_cmd+=("$path")

    run_step "${rm_cmd[@]}"

    if [[ "$DELETE_BRANCH" == true && -n "$branch" && "$branch" != "(detached)" ]]; then
        info "  Deleting local branch: $branch"
        run_step git -C "$SAFE_GIT_CONTEXT" branch -D "$branch"
    elif [[ "$DELETE_BRANCH" == false && -n "$branch" && "$branch" != "(detached)" ]]; then
        info "  Keeping local branch: $branch"
    fi

    info "  Done: $path"
    echo ""
}

# =============================================================================
# BATCH ERROR TRACKING
# =============================================================================

declare -a FAILED_NAMES=()
declare -a SUCCEEDED_NAMES=()

teardown_with_tracking() {
    local idx="$1" name="$2"
    if perform_teardown \
        "${QUEUED_PATHS[idx]}" \
        "${QUEUED_BRANCHES[idx]}" \
        "${QUEUED_PRESERVATION_MSGS[idx]}"; then
        SUCCEEDED_NAMES+=("$name")
    else
        FAILED_NAMES+=("$name")
    fi
}

print_summary() {
    echo "========================================"
    info "Teardown summary:"
    for name in "${SUCCEEDED_NAMES[@]+"${SUCCEEDED_NAMES[@]}"}"; do
        info "  DONE    $name"
    done
    for name in "${FAILED_NAMES[@]+"${FAILED_NAMES[@]}"}"; do
        info "  FAILED  $name"
    done

    if (( ${#FAILED_NAMES[@]} > 0 )); then
        echo ""
        warn "${#FAILED_NAMES[@]} worktree(s) failed to tear down."
        return 1
    fi
    return 0
}

# =============================================================================
# MAIN SCRIPT EXECUTION
# =============================================================================

# --- 1. Parse Arguments ---
while [[ $# -gt 0 ]]; do
    case "$1" in
        -h|--help)           usage; exit 0 ;;
        -d|--base-dir)       shift; WORKTREES_BASE_INPUT="$1"; shift ;;
        -r|--remote)         shift; REMOTE="$1"; shift ;;
        -m|--merge-target)   shift; MERGE_TARGET="$1"; shift ;;
        -k|--keep-branch)    DELETE_BRANCH=false; shift ;;
        -p|--dry-run)        DRY_RUN=true; shift ;;
        --force-dirty)       FORCE_DIRTY=true; shift ;;
        --force-locked)      FORCE_LOCKED=true; shift ;;
        --force-unmerged)    FORCE_UNMERGED=true; shift ;;
        -f|--force)          FORCE_DIRTY=true; FORCE_LOCKED=true; FORCE_UNMERGED=true; shift ;;
        -*)                  err "Unknown flag: $1"; usage >&2; exit 1 ;;
        *)                   TARGET_NAMES+=("$1"); shift ;;
    esac
done

if [[ ${#TARGET_NAMES[@]} -eq 0 ]]; then
    err "No WORKTREE_NAME provided."
    usage >&2; exit 1
fi

# --- 2. Pre-flight Setup ---
if ! git rev-parse --git-dir > /dev/null 2>&1; then
    err "Not inside a git repository."
    exit 1
fi

CURRENT_WORKTREE_ROOT="$(git rev-parse --show-toplevel)"
WORKTREES_BASE="$(resolve_directory_path "$WORKTREES_BASE_INPUT")" || exit 1

load_worktree_registry

# --- 3. Phase 1: Validate all requested worktrees (fail-fast) ---
_LAST_PRES_MSG=""

for name in "${TARGET_NAMES[@]}"; do
    validate_worktree_name "$name"     || exit 1
    resolve_target_worktree "$name"    || exit 1
    check_safety "$name"               || exit 1

    # All three queues are appended together in one place — no drift possible
    QUEUED_PATHS+=("$TARGET_WORKTREE_PATH")
    QUEUED_BRANCHES+=("$TARGET_BRANCH")
    QUEUED_PRESERVATION_MSGS+=("$_LAST_PRES_MSG")
    _LAST_PRES_MSG=""
done

# --- 4. Phase 2: Execute Teardown ---
find_safe_context || exit 1

# Move out of harm's way if CWD is inside a targeted worktree
for qp in "${QUEUED_PATHS[@]}"; do
    if [[ "$PWD" == "$qp" || "$PWD" == "$qp/"* ]]; then
        cd "$SAFE_GIT_CONTEXT"
        break
    fi
done

info "Starting teardown of ${#QUEUED_PATHS[@]} worktree(s)..."
[[ "$DRY_RUN" == true ]] && info "(dry-run mode — no changes will be made)"
echo "----------------------------------------"

# Disable set -e for the teardown loop so we can collect failures
# rather than aborting on the first one.
set +e
for i in "${!QUEUED_PATHS[@]}"; do
    teardown_with_tracking "$i" "${TARGET_NAMES[i]}"
done
set -e

print_summary
exit_code=$?

if [[ "$DRY_RUN" == true && $exit_code -eq 0 ]]; then
    info "Dry run finished. No changes were made."
fi

exit $exit_code
